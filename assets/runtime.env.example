# Copy this file to either:
# - .env.local
# - assets/runtime.env.local
#
# The recap workflow will load these values before it spawns the market-context
# builder and recap renderer, which helps cron/worktree automations inherit the
# same keys you use in local terminal runs.

TWELVEDATA_API_KEY=replace-with-your-twelvedata-key
TUSHARE_TOKEN=replace-with-your-tushare-token
